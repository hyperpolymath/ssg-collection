# Pre-commit hook for shift-ssg
# Install: cp hooks/pre-commit .git/hooks/ && chmod +x .git/hooks/pre-commit

set -e

echo "🔍 Running pre-commit checks..."

# ─────────────────────────────────────────────────────────────────────────────
# 1. Syntax Check
# ─────────────────────────────────────────────────────────────────────────────
echo "📝 Checking adapter syntax..."
for f in adapters/*.js; do
    node --check "$f" 2>/dev/null || {
        echo "❌ Syntax error in $f"
        exit 1
    }
done
echo "✅ Syntax check passed"

# ─────────────────────────────────────────────────────────────────────────────
# 2. Format Check (if Deno available)
# ─────────────────────────────────────────────────────────────────────────────
if command -v deno &> /dev/null; then
    echo "🎨 Checking formatting..."
    if ! deno fmt --check adapters/ 2>/dev/null; then
        echo "⚠️ Formatting issues found. Run: deno fmt adapters/"
        echo "   Or: just fmt"
        # Warning only, don't block commit
    fi
fi

# ─────────────────────────────────────────────────────────────────────────────
# 3. Security Check
# ─────────────────────────────────────────────────────────────────────────────
echo "🔐 Checking for secrets..."

# Check staged files only
staged_files=$(git diff --cached --name-only --diff-filter=ACM)

for file in $staged_files; do
    if [ -f "$file" ]; then
        # Check for hardcoded passwords
        if grep -E "password\s*=\s*['\"][^'\"]+['\"]" "$file" 2>/dev/null; then
            echo "❌ Potential hardcoded password in $file"
            exit 1
        fi

        # Check for API keys
        if grep -E "(api[_-]?key|apikey)\s*=\s*['\"][^'\"]+['\"]" "$file" 2>/dev/null; then
            echo "❌ Potential API key in $file"
            exit 1
        fi
    fi
done
echo "✅ Security check passed"

# ─────────────────────────────────────────────────────────────────────────────
# 4. Lint Check (if Deno available)
# ─────────────────────────────────────────────────────────────────────────────
if command -v deno &> /dev/null; then
    echo "🔎 Running linter..."
    deno lint adapters/ 2>/dev/null || echo "⚠️ Lint warnings present"
fi

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "  ✅ Pre-commit checks passed"
echo "═══════════════════════════════════════════════════════════════"
