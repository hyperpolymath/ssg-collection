#!/bin/bash
# SPDX-License-Identifier: PMPL-1.0-or-later
# SPDX-FileCopyrightText: 2025 Jonathan D.A. Jewell
#
# Pre-push hook for shift-ssg
# Install: cp hooks/pre-push .git/hooks/ && chmod +x .git/hooks/pre-push

set -e

echo "🚀 Running pre-push checks..."

# ─────────────────────────────────────────────────────────────────────────────
# 1. Full Syntax Check
# ─────────────────────────────────────────────────────────────────────────────
echo "📝 Checking all adapter syntax..."
for f in adapters/*.js; do
    node --check "$f" 2>/dev/null || {
        echo "❌ Syntax error in $f"
        exit 1
    }
done
echo "✅ All adapters pass syntax check"

# ─────────────────────────────────────────────────────────────────────────────
# 2. Adapter Validation
# ─────────────────────────────────────────────────────────────────────────────
echo "🔌 Validating adapter exports..."
for adapter in adapters/*.js; do
    name=$(basename "$adapter" .js)

    if ! grep -q "export const name" "$adapter"; then
        echo "❌ Missing 'name' export in $name"
        exit 1
    fi

    if ! grep -q "export const tools" "$adapter"; then
        echo "❌ Missing 'tools' export in $name"
        exit 1
    fi
done
echo "✅ All adapters validated"

# ─────────────────────────────────────────────────────────────────────────────
# 3. Adapter Count Check
# ─────────────────────────────────────────────────────────────────────────────
count=$(ls -1 adapters/*.js | wc -l)
if [ "$count" -lt 28 ]; then
    echo "❌ Expected at least 28 adapters, found $count"
    exit 1
fi
echo "✅ Adapter count: $count"

# ─────────────────────────────────────────────────────────────────────────────
# 4. Documentation Check
# ─────────────────────────────────────────────────────────────────────────────
echo "📚 Checking documentation..."
[ -f "SECURITY.md" ] || { echo "❌ SECURITY.md missing"; exit 1; }
[ -f "CONTRIBUTING.md" ] || { echo "❌ CONTRIBUTING.md missing"; exit 1; }
[ -f "CODE_OF_CONDUCT.md" ] || { echo "❌ CODE_OF_CONDUCT.md missing"; exit 1; }
echo "✅ Required documentation present"

# ─────────────────────────────────────────────────────────────────────────────
# 5. Security Check
# ─────────────────────────────────────────────────────────────────────────────
echo "🔐 Running security check..."
if grep -rE "password\s*=\s*['\"][^'\"]+['\"]" adapters/ 2>/dev/null; then
    echo "❌ Potential hardcoded password found"
    exit 1
fi
echo "✅ Security check passed"

# ─────────────────────────────────────────────────────────────────────────────
# 6. Run Tests (if available)
# ─────────────────────────────────────────────────────────────────────────────
if command -v deno &> /dev/null && [ -d "tests" ]; then
    echo "🧪 Running tests..."
    deno test --allow-all tests/ 2>/dev/null || echo "⚠️ Tests skipped or failed"
fi

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "  ✅ Pre-push checks passed - ready to push"
echo "═══════════════════════════════════════════════════════════════"
