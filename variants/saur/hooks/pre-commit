#!/bin/bash
# SPDX-License-Identifier: PMPL-1.0-or-later
# SPDX-FileCopyrightText: 2025 hyperpolymath
#
# Pre-commit hook for saur-ssg
# Install: cp hooks/pre-commit .git/hooks/ && chmod +x .git/hooks/pre-commit
# Or: just hooks-install

set -euo pipefail

echo "🔍 Running pre-commit checks..."

# ─────────────────────────────────────────────────────────────────────────────
# FORMAT CHECK
# ─────────────────────────────────────────────────────────────────────────────

echo "  → Checking code formatting..."
if command -v deno &> /dev/null; then
    if ! deno fmt --check adapters/ 2>/dev/null; then
        echo "❌ Code is not formatted. Run: just fmt"
        exit 1
    fi
    echo "  ✓ Format OK"
else
    echo "  ⚠ Deno not installed, skipping format check"
fi

# ─────────────────────────────────────────────────────────────────────────────
# LINT CHECK
# ─────────────────────────────────────────────────────────────────────────────

echo "  → Running linter..."
if command -v deno &> /dev/null; then
    if ! deno lint adapters/ 2>/dev/null; then
        echo "❌ Lint errors found. Run: just lint"
        exit 1
    fi
    echo "  ✓ Lint OK"
else
    echo "  ⚠ Deno not installed, skipping lint check"
fi

# ─────────────────────────────────────────────────────────────────────────────
# SECRETS CHECK
# ─────────────────────────────────────────────────────────────────────────────

echo "  → Checking for secrets..."
if grep -rn --include="*.js" -E "(password|secret|api_key|token)\s*[:=]\s*['\"][^'\"]+['\"]" adapters/ 2>/dev/null; then
    echo "❌ Potential secrets found in code!"
    exit 1
fi
echo "  ✓ No secrets detected"

# ─────────────────────────────────────────────────────────────────────────────
# SPDX HEADERS
# ─────────────────────────────────────────────────────────────────────────────

echo "  → Checking SPDX headers..."
missing=0
for f in adapters/*.js; do
    if [ -f "$f" ] && ! grep -q "SPDX-License-Identifier" "$f"; then
        echo "  ❌ Missing SPDX header: $f"
        missing=1
    fi
done
if [ $missing -eq 1 ]; then
    exit 1
fi
echo "  ✓ SPDX headers OK"

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY PATTERNS
# ─────────────────────────────────────────────────────────────────────────────

echo "  → Checking for dangerous patterns..."
if grep -rn "eval(" adapters/ 2>/dev/null; then
    echo "❌ eval() found - security risk!"
    exit 1
fi
if grep -rn "new Function(" adapters/ 2>/dev/null; then
    echo "❌ Function() constructor found - security risk!"
    exit 1
fi
echo "  ✓ No dangerous patterns"

echo ""
echo "✅ All pre-commit checks passed!"
